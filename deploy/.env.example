# ============================================================================
# TESTERE STORE — Production ortam değişkenleri (Yol 1: Tek VPS + Docker)
# ----------------------------------------------------------------------------
# Bu dosyayı `.env` olarak kopyalayın ve DEĞERLERİ DOLDURUN:
#     cp .env.example .env
# `.env` dosyasını ASLA git'e commit etmeyin (deploy/.gitignore bunu engeller).
# docker-compose bu tek dosyadan hem backend hem storefront'u besler.
# ============================================================================

# --- ALAN ADLARI (senin domainlerin) --------------------------------------
# Storefront (müşterilerin gördüğü site) ve backend (API + admin) domainleri.
# DNS'te ikisinin de A kaydı VPS'in IP'sine bakmalı (DEPLOY.md'ye bak).
DOMAIN=testere.com
API_DOMAIN=api.testere.com

# Caddy'nin Let's Encrypt SSL sertifikası için geçerli bir e-posta.
ACME_EMAIL=seninmail@ornek.com

# --- VERİTABANI (PostgreSQL) ------------------------------------------------
POSTGRES_DB=medusa
POSTGRES_USER=medusa
# Güçlü bir şifre üretin:  openssl rand -hex 24
POSTGRES_PASSWORD=BURAYA_GUCLU_DB_SIFRESI

# --- MEDUSA GÜVENLİK SIRLARI -----------------------------------------------
# Her biri için ayrı ayrı üretin:  openssl rand -base64 48
JWT_SECRET=BURAYA_JWT_SECRET
COOKIE_SECRET=BURAYA_COOKIE_SECRET

# --- E-POSTA (Resend) — sipariş/kargo bildirimleri --------------------------
# Boş bırakırsanız e-posta gönderilmez, sadece log'a yazılır (DRY RUN).
RESEND_API_KEY=
RESEND_FROM_EMAIL=siparis@testere.com
RESEND_FROM_NAME=Testere Store

# --- ÖDEME (iyzico) — CANLI anahtarlar --------------------------------------
# Sandbox'tan canlıya geçerken merchant.iyzipay.com > Ayarlar > API Anahtarları
# CANLI: https://api.iyzipay.com  (sandbox DEĞİL)
IYZICO_API_KEY=BURAYA_CANLI_IYZICO_API_KEY
IYZICO_SECRET_KEY=BURAYA_CANLI_IYZICO_SECRET
IYZICO_BASE_URL=https://api.iyzipay.com

# --- STOREFRONT (Next.js) — public anahtarlar -------------------------------
# Publishable key: Admin panel > Settings > Publishable API Keys'ten alın.
# NOT: NEXT_PUBLIC_* değişkenleri build sırasında imaja gömülür; değişirse
# storefront imajını yeniden build etmeniz gerekir (docker compose build).
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_BURAYA_PUBLISHABLE_KEY
NEXT_PUBLIC_DEFAULT_REGION=tr
NEXT_PUBLIC_DEFAULT_CURRENCY=try

# --- Opsiyonel: Analytics / iletişim (boş bırakılabilir) --------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_YANDEX_METRIKA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# AŞAĞIDAKİLER OTOMATİK TÜRETİLİR — normalde dokunmayın.
# docker-compose bunları yukarıdaki DOMAIN/API_DOMAIN'den kurar; buradaki
# değerler container'lar arası (servis adı) ve public URL uyumu içindir.
# ============================================================================
# Backend'in kendini tanıttığı public URL — GÖRSELLER buradan servis edilir
# (https://api.testere.com/static/...). Public HTTPS olduğu için Next image
# optimizer'ı kabul eder → resimler canlıda çalışır (bulut deposu GEREKMEZ).
MEDUSA_BACKEND_URL=https://api.testere.com
STOREFRONT_URL=https://testere.com

# CORS — storefront ve admin origin'leri
STORE_CORS=https://testere.com
ADMIN_CORS=https://api.testere.com
AUTH_CORS=https://testere.com,https://api.testere.com

# iyzico callback (backend domaini üzerinden)
IYZICO_CALLBACK_URL=https://api.testere.com/iyzico/callback

# Storefront → backend (hem server hem tarayıcı tarafı public API)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.testere.com
NEXT_PUBLIC_SITE_URL=https://testere.com
